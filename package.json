{
  "name": "slock-cli",
  "version": "0.1.0",
  "description": "CLI client for Slock platform, designed for agent usage",
  "type": "module",
  "bin": {
    "slock": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/TennyZhuang/slock-cli.git"
  },
  "keywords": ["slock", "cli", "agent", "messaging", "chat"],
  "bugs": {
    "url": "https://github.com/TennyZhuang/slock-cli/issues"
  },
  "homepage": "https://github.com/TennyZhuang/slock-cli#readme",
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
